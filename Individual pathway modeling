def plot_pathway_anabolic(ts, A):
    plt.figure()
    plt.plot(ts, A[:, 0], label="A_gut")
    plt.plot(ts, A[:, 1], label="P_plasma")
    plt.plot(ts, A[:, 2], label="B_brain")
    plt.xlabel("Time")
    plt.ylabel("Concentration / amount (a.u.)")
    plt.title("Anabolic Module: SP² PK (gut → plasma → brain)")
    plt.legend()
    plt.show()

def plot_pathway_catabolic(ts, C):
    plt.figure()
    plt.plot(ts, C[:, 0], label="T_sys")
    plt.plot(ts, C[:, 1], label="T_entry")
    plt.plot(ts, C[:, 2], label="E_expr")
    plt.xlabel("Time")
    plt.ylabel("Vector / expression (a.u.)")
    plt.title("Catabolic Module: AAV-T4 delivery → expression")
    plt.legend()
    plt.show()

def plot_pathway_gm2(ts, G):
    plt.figure()
    plt.plot(ts, G[:, 0], label="G_brain")
    plt.plot(ts, G[:, 1], label="G_liver")
    plt.xlabel("Time")
    plt.ylabel("GM2 burden (a.u.)")
    plt.title("GM2 Metabolism: synthesis vs enzymatic clearance")
    plt.legend()
    plt.show()

def plot_pathway_neuro(ts, Nf):
    plt.figure()
    plt.plot(ts, Nf[:, 0], label="Inflammation I")
    plt.plot(ts, Nf[:, 1], label="Damage D")
    plt.xlabel("Time")
    plt.ylabel("Index (a.u.)")
    plt.title("Neuroinflammatory Cascade: I(t) and D(t)")
    plt.legend()
    plt.show()

def plot_coupled_summary(ts, A, C, G, Nf):
    plt.figure()
    plt.plot(ts, A[:, 2], label="B_brain (SP²)")
    plt.plot(ts, C[:, 2], label="E_expr (HEXA/HEXB)")
    plt.plot(ts, G[:, 0], label="G_brain (GM2)")
    plt.plot(ts, Nf[:, 0], label="I (inflam)")
    plt.xlabel("Time")
    plt.ylabel("a.u.")
    plt.title("Coupled System Summary: B → (G) ← E; G → I")
    plt.legend()
    plt.show()


